// Copy to wifi_secrets.h (same folder) and set your lab Wi-Fi credentials.
// wifi_secrets.h is listed in .gitignore — do not commit passwords.

#ifndef FOREST_WIFI_SECRETS_H
#define FOREST_WIFI_SECRETS_H

// 1 = compile Wi-Fi support. USB always works; Wi-Fi starts only on WIFI_CONNECT
// unless FOREST_WIFI_AUTO_CONNECT is 1.
#define FOREST_ENABLE_WIFI 1
#define FOREST_WIFI_AUTO_CONNECT 1

#define FOREST_WIFI_SSID "YourHotspotOrRouterSSID"
#define FOREST_WIFI_PASS "YourPassword"
#define FOREST_WIFI_TCP_PORT 9876

#endif
