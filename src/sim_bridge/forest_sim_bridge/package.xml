<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>forest_sim_bridge</name>
  <version>0.1.0</version>
  <description>Gazebo-ROS2 bridge nodes for forest-hybrid-ros2-stack (pose, sensors, teleop, cleanup).</description>
  <maintainer email="tese@fe.up.pt">forest-hybrid</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <exec_depend>ament_index_python</exec_depend>
  <exec_depend>builtin_interfaces</exec_depend>
  <exec_depend>geometry_msgs</exec_depend>
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>
  <exec_depend>nav_msgs</exec_depend>
  <exec_depend>rclpy</exec_depend>
  <exec_depend>ros_gz_bridge</exec_depend>
  <exec_depend>rosgraph_msgs</exec_depend>
  <exec_depend>rviz2</exec_depend>
  <exec_depend>sensor_msgs</exec_depend>
  <exec_depend>std_msgs</exec_depend>
  <exec_depend>tf2_msgs</exec_depend>
  <exec_depend>tf2_ros</exec_depend>
  <exec_depend>forest_hybrid_msgs</exec_depend>
  <exec_depend>forest_sensors_cpp</exec_depend>
  <exec_depend>forest_lidar_preprocess_cpp</exec_depend>
  <exec_depend>forest_3d_perception</exec_depend>
  <exec_depend>forest_state_estimation</exec_depend>
  <exec_depend>forest_2d_localization</exec_depend>
  <exec_depend>slam_toolbox</exec_depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
